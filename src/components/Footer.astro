</footer>

<style>
  .footer {
    background: #030810;
    border-top: 1px solid rgba(0,153,255,0.12);
    padding-top: 64px;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 48px;
  }

  @media (max-width: 1024px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-main {
      grid-template-columns: 1fr;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .footer-logo-icon {
    width: 44px;
    height: 44px;
    background: #0099FF;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: white;
    flex-shrink: 0;
  }

  .footer-logo-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.2rem;
    font-weight: 900;
    color: white;
    display: block;
    line-height: 1;
    letter-spacing: 0.05em;
  }

  .footer-logo-tagline {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    font-weight: 500;
    margin-top: 2px;
  }

  .footer-bio {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.7;
    max-width: 360px;
    margin: 0 0 20px;
  }

  .footer-socials {
    display: flex;
    gap: 10px;
  }

  .social-btn {
    width: 38px;
    height: 38px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: all 0.2s;
  }

  .social-btn:hover {
    background: rgba(0,153,255,0.15);
    border-color: rgba(0,153,255,0.4);
    color: #0099FF;
  }

  .footer-nav-title {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin: 0 0 16px;
  }

  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav-list a {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav-list a:hover {
    color: #0099FF;
  }

  .footer-divider {
    height: 1px;
    background: rgba(255,255,255,0.06);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.25);
    margin: 0;
  }

  .footer-bottom-links {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.2);
  }

  .footer-bottom-links a {
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover { color: rgba(255,255,255,0.6); }
</style>
