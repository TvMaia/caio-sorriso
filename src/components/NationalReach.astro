---
const cities = [
  { name: 'São Paulo', state: 'SP', value: 'R$ 23,8M', tier: 1 },
  { name: 'Rio de Janeiro', state: 'RJ', value: 'R$ 10,8M', tier: 1 },
  { name: 'Belo Horizonte', state: 'MG', value: 'R$ 6,5M', tier: 1 },
  { name: 'Porto Alegre', state: 'RS', value: 'R$ 3,1M', tier: 2 },
  { name: 'Recife', state: 'PE', value: 'R$ 3,1M', tier: 2 },
  { name: 'Fortaleza', state: 'CE', value: 'R$ 2,2M', tier: 2 },
  { name: 'Distrito Federal', state: 'DF', value: 'R$ 2,9M', tier: 2 },
  { name: 'Manaus', state: 'AM', value: 'R$ 859K', tier: 3 },
  { name: 'Belém', state: 'PA', value: 'R$ 1,2M', tier: 3 },
  { name: 'Cuiabá', state: 'MT', value: 'R$ 441K', tier: 3 },
  { name: 'Umuarama', state: 'PR', value: 'R$ 2,1M', tier: 2 },
  { name: 'São Luís', state: 'MA', value: 'R$ 1,2M', tier: 3 },
  { name: 'Teresina', state: 'PI', value: 'R$ 840K', tier: 3 },
  { name: 'João Pessoa', state: 'PB', value: 'R$ 731K', tier: 3 },
  { name: 'Boa Vista', state: 'RR', value: 'R$ 211K', tier: 4 },
  { name: 'Macapá', state: 'AP', value: 'R$ 220K', tier: 4 },
  { name: 'Palmas', state: 'TO', value: 'R$ 300K', tier: 4 },
  { name: 'Vitória/Vila Velha', state: 'ES', value: 'R$ 1,6M', tier: 2 },
  { name: 'Santa Maria', state: 'RS', value: 'R$ 590K', tier: 3 },
  { name: 'Passo Fundo', state: 'RS', value: 'R$ 632K', tier: 3 },
];
---

<section class="py-24 bg-bg-primary relative">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(0,153,255,0.3), transparent)"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: content -->
      <div class="animate-on-scroll">
        <div class="section-label">Alcance Nacional</div>
        <h2 class="section-title">
          Do Oiapoque ao<br/>
          <span class="gradient-text">Chuí</span>
        </h2>
        <p class="section-subtitle mb-8">
          Mais de <strong class="text-white">40 praças</strong> em todo o Brasil recebem o sinal da RedeTV! com Caio Sorriso. De capitais a cidades do interior, a mensagem chega onde o esporte pulsa.
        </p>

        <!-- Regions -->
        <div class="regions-grid">
          <div class="region-card">
            <div class="region-flag">🏙️</div>
            <div>
              <div class="region-name">Sudeste</div>
              <div class="region-cities">SP · RJ · MG · ES</div>
            </div>
          </div>
          <div class="region-card">
            <div class="region-flag">🌾</div>
            <div>
              <div class="region-name">Sul</div>
              <div class="region-cities">RS · PR · SC</div>
            </div>
          </div>
          <div class="region-card">
            <div class="region-flag">☀️</div>
            <div>
              <div class="region-name">Nordeste</div>
              <div class="region-cities">PE · CE · BA · MA · PB · PI</div>
            </div>
          </div>
          <div class="region-card">
            <div class="region-flag">🌳</div>
            <div>
              <div class="region-name">Norte</div>
              <div class="region-cities">AM · PA · RR · AP · TO · RO</div>
            </div>
          </div>
          <div class="region-card">
            <div class="region-flag">🏔️</div>
            <div>
              <div class="region-name">Centro-Oeste</div>
              <div class="region-cities">DF · MT · GO · MS</div>
            </div>
          </div>
        </div>

        <a href="#midia-kit" class="btn-outline mt-8 inline-flex">
          Ver cota por praça →
        </a>
      </div>

      <!-- Right: cities list -->
      <div class="animate-on-scroll animate-delay-2">
        <div class="cities-container">
          <div class="cities-header">
            <span>Praça</span>
            <span>Cota de Patrocínio/Ano</span>
          </div>
          <div class="cities-list">
            {cities.map((city) => (
              <div class={`city-row tier-${city.tier}`}>
                <span class="city-name">
                  <span class="city-dot" style={`background: ${city.tier === 1 ? '#FFB400' : city.tier === 2 ? '#0099FF' : city.tier === 3 ? '#00C896' : 'rgba(255,255,255,0.3)'}`}></span>
                  {city.name} <span class="city-state">{city.state}</span>
                </span>
                <span class="city-value">{city.value}</span>
              </div>
            ))}
          </div>

          <!-- Legend -->
          <div class="cities-legend">
            <span class="legend-item"><span class="legend-dot" style="background:#FFB400"></span>Principais praças</span>
            <span class="legend-item"><span class="legend-dot" style="background:#0099FF"></span>Praças regionais</span>
            <span class="legend-item"><span class="legend-dot" style="background:#00C896"></span>Interior</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .regions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .region-card {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #0F1E35;
    border: 1px solid rgba(0,153,255,0.1);
    border-radius: 8px;
    padding: 12px 14px;
  }

  .region-flag { font-size: 1.2rem; }

  .region-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: white;
    margin-bottom: 2px;
  }

  .region-cities {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
  }

  .cities-container {
    background: #0F1E35;
    border: 1px solid rgba(0,153,255,0.15);
    border-radius: 12px;
    overflow: hidden;
  }

  .cities-header {
    display: flex;
    justify-content: space-between;
    padding: 12px 16px;
    background: rgba(0,153,255,0.1);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    border-bottom: 1px solid rgba(0,153,255,0.12);
  }

  .cities-list {
    max-height: 420px;
    overflow-y: auto;
  }

  .cities-list::-webkit-scrollbar { width: 4px; }
  .cities-list::-webkit-scrollbar-thumb { background: rgba(0,153,255,0.3); border-radius: 2px; }

  .city-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.2s;
  }

  .city-row:hover { background: rgba(0,153,255,0.06); }

  .city-name {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.84rem;
    color: rgba(255,255,255,0.8);
    font-weight: 500;
  }

  .city-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .city-state {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    font-weight: 600;
  }

  .city-value {
    font-size: 0.8rem;
    font-weight: 600;
    color: #00C896;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.9rem;
  }

  .cities-legend {
    display: flex;
    gap: 16px;
    padding: 12px 16px;
    border-top: 1px solid rgba(255,255,255,0.05);
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
</style>
