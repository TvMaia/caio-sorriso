---
const socials = [
  {
    name: 'Instagram',
    handle: '@caiosorrisooficial',
    url: 'https://www.instagram.com/caiosorrisooficial/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
    color: '#E1306C',
    stat: 'Instagram',
    cta: 'Seguir no Instagram',
  },
  {
    name: 'YouTube',
    handle: '@caiosorrisooficial',
    url: 'https://www.youtube.com/@caiosorrisooficial',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-2.47 12.35 12.35 0 01-3.82-1.22 12.35 12.35 0 01-3.82 1.22 4.83 4.83 0 01-3.77 2.47A5.12 5.12 0 002 11.5v1a12 12 0 007.45 11.06A3 3 0 0012 24a3 3 0 002.55-1.44A12 12 0 0022 11.5v-1a5.12 5.12 0 00-2.41-4.81zM10 15V9l6 3z"/></svg>`,
    color: '#FF0000',
    stat: 'YouTube',
    cta: 'Assinar o Canal',
  },
  {
    name: 'TikTok',
    handle: '@caiosorrisooficial',
    url: 'https://www.instagram.com/caiosorrisooficial/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-2.47 12.35 12.35 0 01-3.82-1.22 12.35 12.35 0 01-3.82 1.22 4.83 4.83 0 01-3.77 2.47A5.12 5.12 0 002 11.5v1a12 12 0 007.45 11.06A3 3 0 0012 24a3 3 0 002.55-1.44A12 12 0 0022 11.5v-1a5.12 5.12 0 00-2.41-4.81zM10 15V9l6 3z"/></svg>`,
    color: '#010101',
    stat: 'TikTok',
    cta: 'Seguir no TikTok',
  },
];
---

<section id="social" class="py-24 bg-bg-primary relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <div class="section-label justify-center">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        Social
      </div>
      <h2 class="section-title text-center">
        Conectado ao<br/>
        <span class="gradient-text">digital</span>
      </h2>
      <p class="section-subtitle mx-auto text-center">
        Presença ativa e crescente em todas as plataformas. Conteúdo esportivo de alta qualidade todos os dias.
      </p>
    </div>

    <!-- Social cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-16">
      {socials.map((s, i) => (
        <a href={s.url} target="_blank" rel="noopener" class={`social-card animate-on-scroll animate-delay-${i+1}`} style={`--color: ${s.color}`}>
          <div class="social-card-header">
            <div class="social-icon" set:html={s.icon}></div>
            <span class="social-name">{s.name}</span>
          </div>
          <div class="social-handle">{s.handle}</div>
          <div class="social-label">{s.stat}</div>
          <div class="social-cta">{s.cta} →</div>
        </a>
      ))}
    </div>

    <!-- Instagram embed area -->
    <div class="instagram-section animate-on-scroll">
      <div class="instagram-header">
        <div class="flex items-center gap-3">
          <div class="ig-avatar">CS</div>
          <div>
            <div class="ig-name">caiosorrisooficial</div>
            <div class="ig-sub">Apresentador Esportivo</div>
          </div>
        </div>
        <a href="https://www.instagram.com/caiosorrisooficial/" target="_blank" rel="noopener" class="ig-follow-btn">
          Seguir
        </a>
      </div>

      <!-- Grid of placeholder posts -->
      <div class="ig-grid">
        {[1,2,3,4,5,6].map((n) => (
          <a href="https://www.instagram.com/caiosorrisooficial/" target="_blank" rel="noopener" class="ig-post">
            <img
              src={`${import.meta.env.BASE_URL}images/instagram-${n}.jpg`}
              alt={`Post Instagram ${n}`}
              class="ig-post-img"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
            />
            <div class="ig-post-placeholder" style="display:none;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
            <div class="ig-post-overlay">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="none"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            </div>
          </a>
        ))}
      </div>

      <div class="ig-footer">
        <a href="https://www.instagram.com/caiosorrisooficial/" target="_blank" rel="noopener" class="btn-outline w-full justify-center">
          Ver todos os posts no Instagram
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .social-card {
    background: #0F1E35;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .social-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color) 8%, transparent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .social-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 40px color-mix(in srgb, var(--color) 20%, transparent);
    border-color: color-mix(in srgb, var(--color) 40%, transparent);
  }

  .social-card:hover::before { opacity: 1; }

  .social-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .social-icon {
    color: var(--color);
    flex-shrink: 0;
  }

  .social-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.3rem;
    font-weight: 800;
    color: white;
  }

  .social-handle {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
  }

  .social-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color);
    line-height: 1;
    margin-top: 8px;
  }

  .social-cta {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
    transition: color 0.2s;
  }

  .social-card:hover .social-cta { color: white; }

  /* Instagram section */
  .instagram-section {
    background: #0F1E35;
    border: 1px solid rgba(225,48,108,0.2);
    border-radius: 12px;
    overflow: hidden;
  }

  .instagram-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .ig-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #E1306C, #833AB4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: white;
    flex-shrink: 0;
  }

  .ig-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: white;
  }

  .ig-sub {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
  }

  .ig-follow-btn {
    background: #0099FF;
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 8px 20px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .ig-follow-btn:hover { background: #0077CC; }

  .ig-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .ig-post {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    background: #0C1830;
    cursor: pointer;
  }

  .ig-post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .ig-post:hover .ig-post-img { transform: scale(1.05); }

  .ig-post-placeholder {
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    background: #0C1830;
  }

  .ig-post-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .ig-post:hover .ig-post-overlay { opacity: 1; }

  .ig-footer {
    padding: 16px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
</style>
