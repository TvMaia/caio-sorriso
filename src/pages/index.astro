---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import About from '../components/About.astro';
import Programs from '../components/Programs.astro';
import Stats from '../components/Stats.astro';
import NationalReach from '../components/NationalReach.astro';
import MediaKit from '../components/MediaKit.astro';
import SocialMedia from '../components/SocialMedia.astro';
import YouTube from '../components/YouTube.astro';
import Sponsorship from '../components/Sponsorship.astro';
import Products from '../components/Products.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Ticker />
    <About />
    <div class="section-divider"></div>
    <Programs />
    <div class="section-divider"></div>
    <Stats />
    <NationalReach />
    <div class="section-divider"></div>
    <MediaKit />
    <div class="section-divider"></div>
    <SocialMedia />
    <YouTube />
    <div class="section-divider"></div>
    <Sponsorship />
    <div class="section-divider"></div>
    <Products />
    <div class="section-divider"></div>
    <Contact />
  </main>
  <Footer />
</Layout>
