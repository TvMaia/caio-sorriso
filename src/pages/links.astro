---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/assets';

const links = [
  {
    label: 'Site Oficial / Mídia Kit',
    sub: 'Patrocínio, números e contato comercial',
    href: asset(''),
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 2 7v10l10 5 10-5V7L12 2z"/><path d="M2 7l10 5 10-5M12 22V12"/></svg>`,
    external: false,
  },
  {
    label: 'Instagram',
    sub: '@caiosorrisooficial',
    href: 'https://www.instagram.com/caiosorrisooficial/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
    color: '#E1306C',
    external: true,
  },
  {
    label: 'TikTok',
    sub: '@sorrisocaio',
    href: 'https://www.tiktok.com/@sorrisocaio',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.31 1.38V7.3s-1.88.09-3.24-1.48z"/></svg>`,
    color: '#25F4EE',
    external: true,
  },
  {
    label: 'YouTube',
    sub: '@caiosorrisooficial',
    href: 'https://www.youtube.com/@caiosorrisooficial',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    color: '#FF0000',
    external: true,
  },
  {
    label: 'Patrocínio / Contato Comercial',
    sub: 'Anuncie com o Caio Sorriso',
    href: asset('#contato'),
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11l18-5v12L3 13v-2z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
    color: '#FFB400',
    external: false,
  },
];
---

<Layout
  title="Caio Sorriso — Links"
  description="Todos os links oficiais de Caio Sorriso: Instagram, TikTok, YouTube e mídia kit."
>
  <main class="links-page">
    <div class="links-container">
      <div class="profile">
        <div class="avatar">CS</div>
        <h1 class="name">Caio Sorriso</h1>
        <p class="tagline">
          Apresentador esportivo · Band &amp; RedeTV!<br />
          Cobrindo a Copa do Mundo 2026
        </p>
      </div>

      <nav class="link-list">
        {links.map((l) => (
          <a
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener' : undefined}
            class="link-btn"
            style={l.color ? `--color: ${l.color}` : undefined}
          >
            <span class="link-icon" set:html={l.icon}></span>
            <span class="link-text">
              <span class="link-label">{l.label}</span>
              <span class="link-sub">{l.sub}</span>
            </span>
            <svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        ))}
      </nav>
    </div>
  </main>
</Layout>

<style>
  .links-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 20px;
    background: var(--bg);
  }

  .links-container {
    width: 100%;
    max-width: 440px;
  }

  .profile {
    text-align: center;
    margin-bottom: 36px;
  }

  .avatar {
    width: 76px;
    height: 76px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0099FF, #00C896);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    color: white;
    box-shadow: 0 0 30px rgba(0,153,255,0.4);
  }

  .name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2rem;
    font-weight: 900;
    color: white;
    margin: 0 0 8px;
    letter-spacing: 0.04em;
  }

  .tagline {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #8899BB;
    margin: 0;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .link-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #0F1E35;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 14px 18px;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .link-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color, #0099FF) 10%, transparent), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .link-btn:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color, #0099FF) 40%, transparent);
    box-shadow: 0 8px 30px color-mix(in srgb, var(--color, #0099FF) 18%, transparent);
  }

  .link-btn:hover::before { opacity: 1; }

  .link-icon {
    color: var(--color, #0099FF);
    flex-shrink: 0;
    display: flex;
  }

  .link-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .link-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
  }

  .link-sub {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    margin-top: 2px;
  }

  .link-arrow {
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }

  .link-btn:hover .link-arrow {
    transform: translateX(3px);
    color: var(--color, #0099FF);
  }
</style>
